<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GraphicsApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-buttons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GraphicsApp.styles.css" asp-append-version="true" />
</head>
<body style="margin:0;">
    <header>
        <div class="header-container"> 
            <div class="header-left">
                <a class="header-logo"
                       asp-area=""
                       asp-controller="@(User.Identity.IsAuthenticated ? "Home" : "Account")"
                       asp-action="Index">
                    <img src="~/images/logo-green.png" alt="GraphicsApp Logo" class="logo-image" />
                </a>

                    <ul class="header-menu">
                        <li>
                            <a asp-controller="Home" asp-action="Index">Головна</a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li>
                                <a asp-controller="Draw" asp-action="Index">Малювати</a>
                            </li>
                        }
                    </ul>
            </div>
            
            <div class="home-buttons">
                @if(ViewContext.RouteData.Values["controller"]?.ToString() == "Account")
                {}
                else
                {
                    @if (User.Identity.IsAuthenticated)
                    {
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit" class="btn btn-outline-danger">Вийти</button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-outline-primary "
                            asp-controller="Account"
                            asp-action="Index">
                            Увійти
                        </a>
                    }
                }
            </div>
        </div>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - GraphicsApp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
